<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hazel • Your Gentle Companion</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');
        
        :root {
            --primary: #a78bfa;
            --bg: #f8fafc;
        }
        
        body {
            margin: 0;
            font-family: 'Inter', system-ui, sans-serif;
            background: linear-gradient(135deg, #f0f4ff, #e0e7ff);
            color: #334155;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }
        
        .container {
            width: 100%;
            max-width: 420px;
            height: 90vh;
            background: white;
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }
        
        .header {
            background: linear-gradient(90deg, #7c3aed, #c026d3);
            color: white;
            padding: 16px 20px;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        
        .avatar {
            width: 58px;
            height: 58px;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid rgba(255,255,255,0.9);
            box-shadow: 0 6px 16px rgba(0,0,0,0.18);
            animation: gentlePulse 4s infinite ease-in-out;
        }
        
        @keyframes gentlePulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }
        
        .header-info h1 {
            margin: 0;
            font-size: 1.3rem;
            font-weight: 600;
        }
        
        .header-info p {
            margin: 2px 0 0;
            font-size: 0.9rem;
            opacity: 0.95;
        }
        
        .chat-window {
            flex: 1;
            padding: 20px;
            overflow-y: auto;
            background: #f8fafc;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }
        
        .message {
            max-width: 85%;
            padding: 14px 18px;
            border-radius: 20px;
            line-height: 1.5;
            font-size: 1rem;
        }
        
        .user { align-self: flex-end; background: #6366f1; color: white; border-bottom-right-radius: 4px; }
        .bot { align-self: flex-start; background: white; border: 1px solid #e2e8f0; border-bottom-left-radius: 4px; box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
        
        .typing {
            align-self: flex-start;
            display: flex;
            gap: 6px;
            padding: 12px 18px;
            background: white;
            border-radius: 20px;
            border-bottom-left-radius: 4px;
        }
        
        .dot {
            width: 8px; height: 8px; background: #94a3b8; border-radius: 50%;
            animation: typingBounce 1.2s infinite;
        }
        .dot:nth-child(2) { animation-delay: 0.2s; }
        .dot:nth-child(3) { animation-delay: 0.4s; }
        
        @keyframes typingBounce {
            0%, 80%, 100% { transform: translateY(0); }
            40% { transform: translateY(-6px); }
        }
        
        .input-area {
            padding: 16px 20px;
            background: white;
            border-top: 1px solid #e2e8f0;
            display: flex;
            gap: 12px;
        }
        
        input {
            flex: 1;
            padding: 14px 20px;
            border: 1px solid #cbd5e1;
            border-radius: 9999px;
            font-size: 1rem;
            outline: none;
        }
        
        input:focus {
            border-color: #7c3aed;
            box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.1);
        }
        
        button {
            background: #7c3aed;
            color: white;
            border: none;
            width: 48px;
            height: 48px;
            border-radius: 50%;
            cursor: pointer;
            font-size: 1.4rem;
        }
        
        button:hover { transform: scale(1.1); }
        
        .disclaimer {
            font-size: 0.75rem;
            text-align: center;
            padding: 8px;
            background: #fef3c7;
            color: #92400e;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Header with YOUR photo as avatar -->
        <div class="header">
            <img src="https://files.oaiusercontent.com/file-0Z8kL9vX7pQ2mR4tY6uI8oP?se=2026-03-26T00%3A00%3A00Z&sp=r&sv=2024-08-04&sr=b&rscc=max-age%3D3628800%2C%20immutable&rscd=attachment%3B%20filename%3D%22hazel-avatar.jpg%22" 
                 alt="Hazel Avatar" 
                 class="avatar">
            <div class="header-info">
                <h1>Hazel</h1>
                <p>Your gentle companion 🌸</p>
            </div>
        </div>
        
        <div class="chat-window" id="chat">
            <div class="message bot">
                Hi, I'm Hazel 💜<br>
                A caring AI friend here to listen without judgment. 
                How are you feeling today? Remember, I'm not a therapist — if things feel heavy, please reach out to a real person or helpline.
            </div>
        </div>
        
        <div class="disclaimer">
            Hazel is an AI companion, not a licensed mental health professional.
        </div>
        
        <div class="input-area">
            <input type="text" id="userInput" placeholder="Share what's on your mind...">
            <button id="sendBtn">↑</button>
        </div>
    </div>

    <script>
        const chatWindow = document.getElementById('chat');
        const userInput = document.getElementById('userInput');
        const sendBtn = document.getElementById('sendBtn');
        
        // === PUT YOUR API KEY HERE ===
        const API_KEY = 'YOUR_OPENAI_API_KEY_HERE';   // Change to Grok or other if needed
        const API_URL = 'https://api.openai.com/v1/chat/completions';
        
        let conversationHistory = [
            {
                role: "system",
                content: `You are Hazel, a warm, empathetic, and wise young woman in her late 20s with a gentle, nurturing personality. 
                You speak softly and kindly, like a caring big sister or close friend. Use warm language, occasional soft emojis (💜 🌸 🤍), and always validate feelings first.
                
                Guidelines:
                - Listen actively and reflect back what the user shares.
                - Gently suggest small helpful steps (breathing, grounding, journaling, reaching out to friends).
                - Never diagnose or give medical advice.
                - If self-harm, suicide, or crisis is mentioned: show care, strongly encourage professional help, and share https://www.iasp.info/visitors/
                - Keep responses warm but concise (2-4 paragraphs).
                - End with a gentle open question when appropriate.`
            }
        ];

        function addMessage(text, isUser) {
            const msg = document.createElement('div');
            msg.className = `message ${isUser ? 'user' : 'bot'}`;
            msg.innerHTML = isUser ? text : text.replace(/\n/g, '<br>');
            chatWindow.appendChild(msg);
            chatWindow.scrollTop = chatWindow.scrollHeight;
        }

        function showTyping() {
            const typing = document.createElement('div');
            typing.id = 'typing';
            typing.className = 'typing';
            typing.innerHTML = `<div class="dot"></div><div class="dot"></div><div class="dot"></div>`;
            chatWindow.appendChild(typing);
            chatWindow.scrollTop = chatWindow.scrollHeight;
            return typing;
        }

        async function sendMessage() {
            let text = userInput.value.trim();
            if (!text) return;

            addMessage(text, true);
            userInput.value = '';

            const typing = showTyping();

            conversationHistory.push({ role: "user", content: text });

            try {
                const res = await fetch(API_URL, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${API_KEY}`
                    },
                    body: JSON.stringify({
                        model: "gpt-4o-mini",
                        messages: conversationHistory,
                        temperature: 0.75,
                        max_tokens: 650
                    })
                });

                const data = await res.json();
                const reply = data.choices[0].message.content;

                conversationHistory.push({ role: "assistant", content: reply });
                typing.remove();
                addMessage(reply, false);

            } catch (err) {
                typing.remove();
                addMessage("Sorry, I had a little trouble connecting... Could you try again? 💜", false);
            }
        }

        sendBtn.addEventListener('click', sendMessage);
        userInput.addEventListener('keypress', e => { if (e.key === 'Enter') sendMessage(); });
    </script>
</body>
</html>
